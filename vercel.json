{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.css", "use": "@vercel/static" },
    { "src": "*.js", "use": "@vercel/static" },
    { "src": "main.py", "use": "@vercel/python" }
  ],
  "rewrites": [
    {
      "source": "/((?!.*\\.(css|js|html|png|jpg|jpeg|svg|ico|json)$).*)",
      "destination": "/main.py"
    }
  ]
}
